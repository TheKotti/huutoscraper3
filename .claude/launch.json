{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "vite-client",
      "runtimeExecutable": "npx",
      "runtimeArgs": ["vite", "--port", "5173"],
      "port": 5173
    },
    {
      "name": "server",
      "runtimeExecutable": "npm",
